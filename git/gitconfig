[include]
  path = ~/.gitalias.txt

# Load private git configuration from private config
# User name and email are now set in ~/.config/private/dotfiles.conf
# Git will automatically pick up these environment variables:
# GIT_USER_NAME and GIT_USER_EMAIL

# To override, you can also create ~/.config/private/git.conf with:
# [user]
#   name = Your Name
#   email = your.email@example.com
[includeIf "gitdir:~/"]
  path = ~/.config/private/git.conf
[credential]
	helper = store
[core]
	hooksPath = /Users/huangcan/.git-hooks
	quotepath = false
[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
