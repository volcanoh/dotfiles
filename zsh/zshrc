# Modern Zsh Configuration
# Modular configuration with Oh My Zsh, Antigen, and Powerlevel10k

# Performance profiling (uncomment to debug startup time)
# zmodload zsh/zprof

# Enable Powerlevel10k instant prompt
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# XDG Base Directory Specification
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"

# Dotfiles directory
export DOTFILES_DIR="$HOME/.dotfiles"

# Load private configuration early (before other exports)
PRIVATE_CONFIG="$HOME/.config/private/dotfiles.conf"
if [[ -f "$PRIVATE_CONFIG" ]]; then
    source "$PRIVATE_CONFIG"
else
    # Warn user if private config is missing
    if [[ "${TERM:-}" != "dumb" && -z "${DOTFILES_SETUP_RUNNING:-}" ]]; then
        echo "⚠️  Private configuration not found at $PRIVATE_CONFIG"
        echo "💡 Run ./zsh/setup.sh to create it"
    fi
fi

# Load environment variables and exports first
[[ -f "$DOTFILES_DIR/zsh/exports/main.zsh" ]] && source "$DOTFILES_DIR/zsh/exports/main.zsh"

# Oh My Zsh configuration
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="robbyrussell"  # Will be overridden by Powerlevel10k

# Oh My Zsh settings
CASE_SENSITIVE="false"
HYPHEN_INSENSITIVE="true"
DISABLE_AUTO_UPDATE="false"
DISABLE_UPDATE_PROMPT="false"
export UPDATE_ZSH_DAYS=13
DISABLE_MAGIC_FUNCTIONS="false"
DISABLE_LS_COLORS="false"
DISABLE_AUTO_TITLE="false"
ENABLE_CORRECTION="false"
COMPLETION_WAITING_DOTS="true"
DISABLE_UNTRACKED_FILES_DIRTY="false"

# Oh My Zsh plugins (minimal set for faster startup)
plugins=(
    git
    web-search
    copypath
    copyfile
    copybuffer
)

# Load Oh My Zsh
if [[ -d "$ZSH" ]]; then
    source $ZSH/oh-my-zsh.sh
fi

# Antigen setup for additional plugins and theme (only if available)
if [[ -f "$HOME/.antigen.zsh" ]]; then
    source ~/.antigen.zsh

    antigen use oh-my-zsh

    # Enhanced plugins via Antigen (only load if not already loaded by Oh My Zsh)
    antigen bundle zsh-users/zsh-autosuggestions
    antigen bundle zsh-users/zsh-completions
    antigen bundle zsh-users/zsh-syntax-highlighting

    # Powerlevel10k theme
    antigen theme romkatv/powerlevel10k

    antigen apply
else
    # Fallback: inform user that enhanced features are not available
    if [[ "${TERM:-}" != "dumb" ]]; then
        echo "Note: Antigen not found. Run the setup script to install enhanced zsh features."
    fi
fi

# Load main configuration
[[ -f "$DOTFILES_DIR/zsh/config/main.zsh" ]] && source "$DOTFILES_DIR/zsh/config/main.zsh"

# Load aliases
[[ -f "$DOTFILES_DIR/zsh/aliases/main.zsh" ]] && source "$DOTFILES_DIR/zsh/aliases/main.zsh"

# Load functions
[[ -f "$DOTFILES_DIR/zsh/functions/main.zsh" ]] && source "$DOTFILES_DIR/zsh/functions/main.zsh"

# Load additional custom configurations
for config_file in "$DOTFILES_DIR/zsh/config"/*.zsh; do
    [[ -f "$config_file" && "$(basename "$config_file")" != "main.zsh" ]] && source "$config_file"
done

# Load additional aliases
for alias_file in "$DOTFILES_DIR/zsh/aliases"/*.zsh; do
    [[ -f "$alias_file" && "$(basename "$alias_file")" != "main.zsh" ]] && source "$alias_file"
done

# Load additional functions
for func_file in "$DOTFILES_DIR/zsh/functions"/*.zsh; do
    [[ -f "$func_file" && "$(basename "$func_file")" != "main.zsh" ]] && source "$func_file"
done

# Load Powerlevel10k configuration
[[ -f ~/.p10k.zsh ]] && source ~/.p10k.zsh

